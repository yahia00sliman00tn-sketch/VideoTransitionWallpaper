<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="80dp"
            android:paddingBottom="40dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎬"
                android:textSize="72sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transition"
                android:textColor="#80FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="48dp"/>

            <!-- بطاقة الوضع -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODE"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvMode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎬 فيديو واحد"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <Switch
                        android:id="@+id/switchDualMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FFFFFF"
                        android:trackTint="#4361EE"/>

                </LinearLayout>

            </LinearLayout>

            <!-- بطاقة فيديو 1 — Lock Screen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒 LOCK SCREEN VIDEO"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvStatusLock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_video"
                    android:textColor="#FF5555"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSelectLock"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/choose_video"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_glass"/>

            </LinearLayout>

            <!-- بطاقة فيديو 2 — Unlock (تظهر فقط في وضع المزدوج) -->
            <LinearLayout
                android:id="@+id/cardUnlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_card"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 UNLOCK VIDEO"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvStatusUnlock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_video"
                    android:textColor="#FF5555"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSelectUnlock"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/choose_video"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_glass"/>

            </LinearLayout>

            <!-- بطاقة اللون -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/color_label"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:id="@+id/colorPreview"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/color_circle"
                        android:layout_marginRight="16dp"/>

                    <TextView
                        android:id="@+id/tvColorHex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#6200EE"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <Button
                    android:id="@+id/btnPickColor"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/pick_color"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_glass"/>

            </LinearLayout>

            <!-- زر التفعيل -->
            <Button
                android:id="@+id/btnSetWallpaper"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/set_wallpaper"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:enabled="false"
                android:layout_marginBottom="12dp"/>

            <!-- زر Reset -->
            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/reset"
                android:textColor="#80FFFFFF"
                android:textSize="15sp"
                android:background="@drawable/btn_glass"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
