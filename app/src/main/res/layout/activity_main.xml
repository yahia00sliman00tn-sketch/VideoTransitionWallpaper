<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0D0D0D">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎬"
        android:textSize="64sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Video Transition Wallpaper"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الفريم الأول = شاشة القفل&#10;الفريم الأخير = الشاشة الرئيسية"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="لم يتم اختيار فيديو بعد"
        android:textColor="#FF5555"
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <View
        android:id="@+id/colorPreview"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        android:background="#6200EE"/>

    <Button
        android:id="@+id/btnPickColor"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎨 اختر لون Material You"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnSelectVideo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="اختر فيديو"
        android:textSize="16sp"
        android:backgroundTint="#333333"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnSetWallpaper"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="تفعيل كخلفية"
        android:textSize="16sp"
        android:enabled="false"/>

</LinearLayout>
